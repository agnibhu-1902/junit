# LLM Configuration
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-oss-20b:free
LLM_TEMPERATURE=0.2
OPENROUTER_API_KEY=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

# Other fast free models to try (just change LLM_MODEL):
#   google/gemini-2.0-flash-exp:free
#   mistralai/mistral-7b-instruct:free
#   deepseek/deepseek-r1:free

# Optional: switch provider
# LLM_PROVIDER=ollama
# LLM_MODEL=codellama
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=grok
# LLM_MODEL=grok-3-mini
# GROK_API_KEY=your-xai-api-key-here

# Bitbucket Credentials (only needed for Bitbucket input)
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
CLONE_BASE_DIR=/tmp/junit_pipeline_repos

# Pipeline Thresholds
COVERAGE_THRESHOLD=80.0
TEST_PASS_THRESHOLD=80.0
MAX_COVERAGE_ITERATIONS=5
MAX_TEST_PASS_ITERATIONS=5

# Maven / Java
MAVEN_CMD=mvn
JAVA_HOME=/usr/lib/jvm/java-25-openjdk-amd64
