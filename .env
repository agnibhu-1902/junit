# LLM Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.2
OLLAMA_BASE_URL=http://localhost:11434

# Optional cloud LLM keys (only needed if you switch LLM_PROVIDER)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Bitbucket Credentials (only needed for Bitbucket input)
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
CLONE_BASE_DIR=/tmp/junit_pipeline_repos

# Pipeline Thresholds
COVERAGE_THRESHOLD=80.0
TEST_PASS_THRESHOLD=80.0
MAX_COVERAGE_ITERATIONS=5
MAX_TEST_PASS_ITERATIONS=5

# Maven / Java
MAVEN_CMD=mvn
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
