# ── LLM Configuration ─────────────────────────────────────────────────────────
# Default: Grok (xAI) — get a free API key at https://console.x.ai
# Available models: grok-3-mini (fast), grok-3 (powerful), grok-2

LLM_PROVIDER=grok
LLM_MODEL=grok-3-mini
LLM_TEMPERATURE=0.2
GROK_API_KEY=your-xai-api-key-here

# Optional: switch to another provider by changing LLM_PROVIDER
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ── Bitbucket Credentials (only needed for Bitbucket input) ───────────────────
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
CLONE_BASE_DIR=/tmp/junit_pipeline_repos

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
COVERAGE_THRESHOLD=80.0
TEST_PASS_THRESHOLD=80.0
MAX_COVERAGE_ITERATIONS=5
MAX_TEST_PASS_ITERATIONS=5

# ── Maven / Java ──────────────────────────────────────────────────────────────
MAVEN_CMD=mvn
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
