# ── LLM Configuration ─────────────────────────────────────────────────────────
# Default: Ollama (free, local, no API key needed)
# Install Ollama: https://ollama.com
# Then pull a model: ollama pull llama3.2
#
# Recommended models for code generation:
#   llama3.2        - fast, good general purpose (default)
#   codellama       - fine-tuned for code tasks
#   llama3.1:8b     - larger, better reasoning
#   deepseek-coder  - strong at Java/code generation

LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.2
OLLAMA_BASE_URL=http://localhost:11434

# Optional: switch to OpenAI or Anthropic by changing LLM_PROVIDER
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ── Bitbucket Credentials (only needed for Bitbucket input) ───────────────────
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
CLONE_BASE_DIR=/tmp/junit_pipeline_repos

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
COVERAGE_THRESHOLD=80.0
TEST_PASS_THRESHOLD=80.0
MAX_COVERAGE_ITERATIONS=5
MAX_TEST_PASS_ITERATIONS=5

# ── Maven / Java ──────────────────────────────────────────────────────────────
MAVEN_CMD=mvn
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
