# ── LLM Configuration ─────────────────────────────────────────────────────────
# Default: OpenRouter (free tier, fast, no local GPU needed)
# Get a free key at: https://openrouter.ai/keys
#
# Fast free models (verified available May 2026):
#   meta-llama/llama-3.3-70b-instruct:free   ← best for code (default)
#   openai/gpt-oss-120b:free                  ← OpenAI OSS model
#   openai/gpt-oss-20b:free                   ← faster, lighter
#   nvidia/nemotron-3-super-120b-a12b:free    ← strong reasoning
#   nousresearch/hermes-3-llama-3.1-405b:free ← large, capable
#   openrouter/free                           ← auto-routes to any free model

LLM_PROVIDER=openrouter
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_TEMPERATURE=0.2
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: switch to another provider
# LLM_PROVIDER=ollama
# LLM_MODEL=codellama
# OLLAMA_BASE_URL=http://localhost:11434

# LLM_PROVIDER=grok
# LLM_MODEL=grok-3-mini
# GROK_API_KEY=your-xai-api-key-here

# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ── Bitbucket Credentials ─────────────────────────────────────────────────────
BITBUCKET_USERNAME=your-username
BITBUCKET_APP_PASSWORD=your-app-password
BITBUCKET_WORKSPACE=your-workspace
CLONE_BASE_DIR=/tmp/junit_pipeline_repos

# ── Pipeline Thresholds ───────────────────────────────────────────────────────
COVERAGE_THRESHOLD=80.0
TEST_PASS_THRESHOLD=80.0
MAX_COVERAGE_ITERATIONS=5
MAX_TEST_PASS_ITERATIONS=5

# ── Maven / Java ──────────────────────────────────────────────────────────────
MAVEN_CMD=mvn
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
